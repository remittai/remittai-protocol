# RemittAI Configuration
# Copy this to .env and fill in your values
# NEVER commit .env to git

# Network: testnet or mainnet
STELLAR_NETWORK=testnet

# Issuer account (creates and issues $RMTAI)
ISSUER_SECRET_KEY=S...your_issuer_secret_key

# Distribution account (holds and distributes tokens)
DISTRIBUTION_SECRET_KEY=S...your_distribution_secret_key

# Treasury account (reserve fund)
TREASURY_SECRET_KEY=S...your_treasury_secret_key

# Horizon server URLs
TESTNET_HORIZON=https://horizon-testnet.stellar.org
MAINNET_HORIZON=https://horizon.stellar.org
